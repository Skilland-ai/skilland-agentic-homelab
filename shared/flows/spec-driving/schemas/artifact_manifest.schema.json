{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpecDrivingArtifactManifest",
  "type": "object",
  "required": ["case_id", "run_id", "artifacts"],
  "properties": {
    "case_id": { "type": "string" },
    "run_id": { "type": "string" },
    "artifacts": {
      "type": "object",
      "patternProperties": {
        "^(00|01|02|03|04|06)$": {
          "type": "object",
          "required": [
            "stage_id",
            "expected_path",
            "status",
            "iteration_count",
            "latest_verdict"
          ],
          "properties": {
            "stage_id": { "type": "string", "enum": ["00", "01", "02", "03", "04", "06"] },
            "expected_path": { "type": "string" },
            "current_path": { "type": ["string", "null"] },
            "latest_review_path": { "type": ["string", "null"] },
            "approved_review_path": { "type": ["string", "null"] },
            "latest_verdict": {
              "type": ["string", "null"],
              "enum": ["PASS", "FAIL", "BLOCKED", "SKIPPED", null]
            },
            "iteration_count": { "type": "integer", "minimum": 0 },
            "source_required": { "type": "boolean" },
            "status": {
              "type": "string",
              "enum": [
                "PENDING",
                "READY",
                "RUNNING",
                "IN_REVIEW",
                "REVISION_REQUIRED",
                "PASSED",
                "FAILED",
                "BLOCKED",
                "SKIPPED"
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
